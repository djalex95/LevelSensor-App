name: fuellstand_app
description: BLE-App für den NMEA2000-Füllstandsensor (Würth Proteus-e)
publish_to: 'none'
version: 1.0.0+1

environment:
  sdk: '>=3.0.0 <4.0.0'
  flutter: '>=3.10.0'

dependencies:
  flutter:
    sdk: flutter
  flutter_blue_plus: ^1.32.12
  permission_handler: ^11.3.1

dev_dependencies:
  flutter_lints: ^3.0.0

flutter:
  uses-material-design: true
